{
  "packages": {
    ".": {
      "release-type": "simple",
      "extra-files": [
        {
          "type": "regex",
          "path": "pom.xml",
          "regex": "<version>([0-9]+\\.[0-9]+\\.[0-9]+.*)</version>"
        },
        {
          "type": "regex",
          "path": "README.md",
          "regex": "<version>([0-9]+\\.[0-9]+\\.[0-9]+.*)</version>"
        }
      ]
    }
  }
}