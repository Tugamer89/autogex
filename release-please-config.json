{
  "packages": {
    ".": {
      "release-type": "simple",
      "extra-files": [
        {
          "type": "xml",
          "path": "pom.xml",
          "xpath": "/*[local-name()='project']/*[local-name()='version']"
        },
        {
          "type": "generic",
          "path": "README.md"
        },
        {
          "type": "generic",
          "path": ".github/ISSUE_TEMPLATE/bug_report.yml"
        }
      ]
    }
  }
}